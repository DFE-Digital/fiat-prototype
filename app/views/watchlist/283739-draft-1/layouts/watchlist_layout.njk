{% extends "/watchlist/283739-draft-1/layouts/main.njk" %}

{% set pageTitle = "Watchlist" %}
{% set pageHeading = pageTitle %}

{% block content %} 

  {% set addWatchlistItem %}
    <h1 class="govuk-notification-banner__heading">
      School added to watchlist
    </h1>
  {% endset %}

  {% set removeWatchlistItem %}
    <h1 class="govuk-notification-banner__heading">
      School removed from watchlist
    </h1>
  {% endset %}

  {% if (uriLastPart === "watchlist-confirm-school") %}
    {{ govukNotificationBanner({
      html: addWatchlistItem,
      type: "success"
    }) }}
  {% endif %}

    {% if (uriLastPart === "watchlist-remove-school") %}
    {{ govukNotificationBanner({
      html: removeWatchlistItem,
      type: "success"
    }) }}
  {% endif %}

  <div class="govuk-grid-row">

    <div class="govuk-grid-column-full">

      {# Start of school content block #}

      {% block watchlistContent %}
        Text goes here, override this by overriding the block
      {% endblock %}

    </div>
  </div>

{% endblock %}

