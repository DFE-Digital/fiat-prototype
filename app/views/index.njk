{% extends "layouts/main.njk" %}

{% set pageTitle = "Home" %}

{% block content %}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    <h1 class="govuk-heading-xl">
      {# {{ serviceName }} current prototypes #}
      Current prototypes
    </h1>

    <p class="govuk-caption-l">
      Ongoing design work and prototypes of features and iterations for the FAST project.
    </p>

    <p class="govuk-body-m govuk-!-margin-top-5">
      Use the prototype archive to see previous prototypes used for work developed and released to the live product.
    </p>

    {{ govukButton({
      text: "View the prototype archive",
      classes: "govuk-button--secondary",
      href: "old-protos"
    }) }}

  </div>
</div>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-three-quarters">    

    <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
    
    {# small-iterations #}
    {% include "/small-iterations-current/index-content/content.njk" %}

  </div>
</div>

{% endblock %}
