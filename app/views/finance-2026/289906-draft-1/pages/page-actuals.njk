{% extends "finance-2026/289906-draft-1/layouts/trust_layout.njk" %}

{% set pageTitle = "Abbey Academies Trust" %}
{% set pageHeading = pageTitle %}

{# Set an active state on the appropraite primary nav item #}
{% set navActive = "finances" %}

{# Set an active state on the appropraite secondary nav item #}
{% set subPageHeading = "Actuals" %}
{% set subNavActive = "actuals" %}

{# Custom block for the main content area of a trust page #}
{% block trustContent %}

  <h2 class="govuk-heading-l">
      Finances
  </h2>

  {# Sub-nav to flick through data sets #}
  {% include "../parts/sub_nav.njk" %}

  <h2 class="govuk-heading-m">
      Actuals for the year 2024/2025
  </h2>

  <p class="govuk-body">
    These figures can also be found in the <a href="#" target="_blank">Financial Benchmarking Tool</a> (opens in a new tab).
  </p>

  {{ govukWarningText({
    html: "The figures below are not for official use." + '<br>' + "For more detailed information, complete the SFSO Commissioning form.",
    iconFallbackText: "Warning"
  }) }}

  {# Has actuals table #}
  {% include "../tables/table-actuals.njk" %}

  {# Has actuals explanation #}
  {% include "../parts/explainer-actuals.njk" %}

  {# Has sources and updates #}
  {% include "../parts/sourcesUpdates-actuals.njk" %}

  {# <hr class="govuk-section-break govuk-section-break--s"> #}

{% endblock %}

